# ============================================================
# Wallet Watch — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# The values below are placeholders — all real credentials
# shown in any previous version of this file have been rotated.
# ============================================================

# ── Telegram ──────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ── Supabase ──────────────────────────────────────────────────
# Use the SERVICE ROLE key (not the anon key) for server-side ops
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-here

# ── OpenRouter (LLM) ──────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-key-here
# Optional backup keys for rotation (OPENROUTER_API_KEY_2, _3 …)

# ── AI Model ──────────────────────────────────────────────────
AI_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# ── Encryption (NEW — required for secure secret storage) ─────
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# This key encrypts any secrets written to the Supabase config table.
# Keep it ONLY in environment variables — never in the database.
ENCRYPTION_KEY=your-fernet-key-here

# ── Rate Limiting (optional — defaults shown) ─────────────────
RATE_LIMIT_MESSAGES=20   # max messages per window
RATE_LIMIT_WINDOW=60     # window in seconds
RATE_LIMIT_BURST=5       # max messages per 10-second burst

# ── Server ────────────────────────────────────────────────────
PORT=8000
